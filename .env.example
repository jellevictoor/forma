# PostgreSQL connection string
# For local dev with docker-compose: postgresql://forma:forma@localhost:5433/forma
# For Neon: postgresql://user:pass@ep-xxx.neon.tech/forma?sslmode=require
DATABASE_URL=postgresql://forma:forma@localhost:5433/forma

# Strava API credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_ACCESS_TOKEN=your_access_token
STRAVA_REFRESH_TOKEN=your_refresh_token

# Google Gemini API (free tier at aistudio.google.com)
GEMINI_API_KEY=
